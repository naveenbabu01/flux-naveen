# ─────────────────────────────────────────────────────────────────────────────
# Azure DevOps MCP Server — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to Git — it's in .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Azure Service Principal ───────────────────────────────────────────────────
# Create with: az ad sp create-for-rbac --name "mcp-server-sp" --role Contributor
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# ── AKS Cluster ───────────────────────────────────────────────────────────────
AKS_RESOURCE_GROUP=rg-test
AKS_CLUSTER_NAME=aks-test

# ── GitHub ────────────────────────────────────────────────────────────────────
# Create at: https://github.com/settings/tokens (needs: repo, workflow scopes)
GITHUB_TOKEN=ghp_your_github_token_here
GITHUB_API_URL=https://api.github.com

# ── Azure Application Insights ────────────────────────────────────────────────
# Get from: Azure Portal → App Insights → Configure → API Access
APP_INSIGHTS_APP_ID=your-app-insights-app-id
APP_INSIGHTS_API_KEY=your-app-insights-api-key

# ── Azure Log Analytics ───────────────────────────────────────────────────────
LOG_ANALYTICS_WORKSPACE_ID=your-log-analytics-workspace-id

# ── Jira ──────────────────────────────────────────────────────────────────────
# Create token at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_DEFAULT_PROJECT=SUP
