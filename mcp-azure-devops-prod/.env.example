# Environment variables for local development
# For production: secrets come from Azure Key Vault (no .env needed)

# Azure (non-sensitive)
AZURE_SUBSCRIPTION_ID=9f6136f9-c8b1-414d-9a23-a40c0023225e
AZURE_TENANT_ID=d6df76dd-f7d2-438a-9d44-6e33a0d648e9
AKS_RESOURCE_GROUP=rg-test
AKS_CLUSTER_NAME=aks-test

# Key Vault (leave empty for local dev — will use env vars below instead)
KEY_VAULT_NAME=

# Transport mode (stdio for local Claude Desktop, http for AKS)
TRANSPORT=stdio
PORT=8000

# Secrets (ONLY for local dev — in production these come from Key Vault)
GITHUB_TOKEN=your-github-pat-here
JIRA_URL=https://naveenmcp.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your-jira-token-here
JIRA_DEFAULT_PROJECT=SUP

# App Insights (optional)
APP_INSIGHTS_APP_ID=
APP_INSIGHTS_API_KEY=
